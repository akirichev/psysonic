{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "windows": {
      "signCommand": {
        "cmd": "REPLACE_WITH_FULL_PATH_TO_SIGNTOOL_EXE",
        "args": [
          "sign",
          "/tr", "REPLACE_WITH_TIMESTAMP_URL",
          "/td", "sha256",
          "/fd", "sha256",
          "/sha1", "REPLACE_WITH_CERT_THUMBPRINT_HEX",
          "%1"
        ]
      }
    }
  }
}
